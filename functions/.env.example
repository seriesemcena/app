# Copie para functions/.env apenas no emulador. Em produção, use um arquivo
# .env.<PROJECT_ID> ignorado pelo Git. Segredos ficam no Secret Manager.
ADMIN_ALLOWED_ORIGINS=http://127.0.0.1:4173
CLOUDFLARE_ACCESS_ENFORCEMENT=disabled
CLOUDFLARE_ACCESS_TEAM_DOMAIN=
CLOUDFLARE_ACCESS_AUDIENCE=
APP_CHECK_ENFORCEMENT=monitor

# Bypass explícito e exclusivo do Emulator. Nunca publicar como true.
ADMIN_EMULATOR_BYPASS=false
