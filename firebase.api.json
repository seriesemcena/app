{
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "public": "api-hosting",
    "cleanUrls": true,
    "trailingSlash": false,
    "rewrites": [
      {
        "source": "/v1/**",
        "function": {
          "functionId": "centralApi",
          "region": "us-central1"
        }
      }
    ],
    "headers": [
      {
        "source": "/**",
        "headers": [
          { "key": "Cache-Control", "value": "private, no-store, max-age=0" },
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "X-Frame-Options", "value": "DENY" },
          { "key": "Referrer-Policy", "value": "no-referrer" }
        ]
      }
    ]
  }
}
