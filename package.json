{
  "name": "series-em-cena-web",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "PATH=/Users/igorfreitas/.nvm/versions/node/v22.22.3/bin:$PATH next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "test": "node --test tests/*.test.mjs",
    "test:security": "node --test tests/security/*.test.mjs",
    "test:functions": "node --test tests/security/*.test.mjs",
    "test:rules": "CI=true XDG_CONFIG_HOME=/tmp/maratonou-firebase-config firebase emulators:exec --project demo-maratonou --only firestore \"node --test tests/emulator/*.test.mjs\"",
    "admin:dev": "npm run dev --workspace @maratonou/admin",
    "admin:build": "npm run build --workspace @maratonou/admin",
    "admin:bootstrap": "node scripts/admin/bootstrap-admin.mjs",
    "firebase:emulators": "firebase emulators:start --project demo-maratonou",
    "migrate:firebase:dry": "node scripts/migrations/optimize-firestore.mjs",
    "migrate:firebase:apply": "node scripts/migrations/optimize-firestore.mjs --apply",
    "build:mobile": "PATH=/Users/igorfreitas/.nvm/versions/node/v22.22.3/bin:$PATH CAPACITOR_SERVER_URL=https://maratonou.com npx cap sync",
    "cap:sync": "PATH=/Users/igorfreitas/.nvm/versions/node/v22.22.3/bin:$PATH CAPACITOR_SERVER_URL=https://maratonou.com npx cap sync",
    "cap:sync:local": "PATH=/Users/igorfreitas/.nvm/versions/node/v22.22.3/bin:$PATH CAPACITOR_SERVER_URL=http://127.0.0.1:3000 npx cap sync",
    "cap:android": "PATH=/Users/igorfreitas/.nvm/versions/node/v22.22.3/bin:$PATH npx cap open android",
    "cap:ios": "PATH=/Users/igorfreitas/.nvm/versions/node/v22.22.3/bin:$PATH npx cap open ios",
    "cap:init": "PATH=/Users/igorfreitas/.nvm/versions/node/v22.22.3/bin:$PATH npx cap add android && PATH=/Users/igorfreitas/.nvm/versions/node/v22.22.3/bin:$PATH npx cap add ios"
  },
  "dependencies": {
    "@capacitor-firebase/authentication": "^8.3.0",
    "@capacitor-firebase/messaging": "^8.3.0",
    "@capacitor/android": "^8.3.1",
    "@capacitor/app": "^8.1.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@solar-icons/react": "^1.1.1",
    "@types/jszip": "^3.4.0",
    "firebase": "^12.12.1",
    "firebase-admin": "^13.10.0",
    "i18next": "^26.3.6",
    "jszip": "^3.10.1",
    "next": "^16.2.10",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.10"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.1",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@types/node": "^20",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "firebase-tools": "^15.24.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2"
  }
}
