rules_version = '2';

// ═══════════════════════════════════════════════════════════════
// Séries em Cena — Firestore security rules
//
// This file is the versioned source of truth. Deploy by pasting in
// Firebase Console → Firestore Database → Rules (the project has no
// firebase-tools setup, so the console is the deploy path).
//
// Design notes:
// • Follower counts are DERIVED client-side from following_list
//   queries — there is deliberately no cross-user counter write.
// • reviews/{titleKey} legacy docs (the old `items` array model)
//   are frozen read-only; new reviews live in the items/
//   subcollection where authorUid can be enforced per doc.
// ═══════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ────────────────────────────────────────────────
    // Profiles are public inside the app (search, /user/<slug>,
    // follower lookups) → any signed-in account may read.
    // Only the owner writes.
    match /users/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;

      // Owner-only data (FCM push tokens live here — they must NOT
      // sit on the public doc above).
      match /private/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ── Reviews ──────────────────────────────────────────────
    match /reviews/{titleKey} {
      // Legacy array docs: readable history, frozen for writes.
      allow read:  if true;
      allow write: if false;

      // One doc per review; authorUid pins it to its creator.
      match /items/{reviewId} {
        allow read:   if true;
        allow create: if request.auth != null
                      && request.resource.data.authorUid == request.auth.uid;
        allow delete: if request.auth != null
                      && resource.data.authorUid == request.auth.uid;
        // The author may edit their review; anyone signed in may
        // ONLY touch likes/replies (and may not reassign authorship).
        allow update: if request.auth != null
                      && request.resource.data.authorUid == resource.data.authorUid
                      && (
                           resource.data.authorUid == request.auth.uid
                           || request.resource.data.diff(resource.data)
                                .affectedKeys()
                                .hasOnly(['likedBy', 'likes', 'replies'])
                         );
      }
    }

    // ── Activity feed ────────────────────────────────────────
    // Posts carry the author's uid; only that author may create
    // them under their name, and only they may delete.
    match /activity/{id} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // ── Notifications ────────────────────────────────────────
    // Anyone signed in may create (that's how "X followed you"
    // reaches another account). Only the recipient reads them,
    // and the only mutation allowed is flipping `read`.
    match /notifications/{id} {
      allow read:   if request.auth != null
                    && resource.data.recipientId == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.recipientId is string;
      allow update: if request.auth != null
                    && resource.data.recipientId == request.auth.uid
                    && request.resource.data.diff(resource.data)
                         .affectedKeys().hasOnly(['read']);
      allow delete: if request.auth != null
                    && resource.data.recipientId == request.auth.uid;
    }

    // ── Feed reactions ───────────────────────────────────────
    // reactions/{feedItemId} → { users: { uid: emoji } }.
    // Each account may only add/change/remove ITS OWN map entry.
    match /reactions/{feedItemId} {
      allow read:   if true;
      allow create: if request.auth != null
                    && request.resource.data.keys().hasOnly(['users'])
                    && request.resource.data.users.keys()
                         .hasOnly([request.auth.uid]);
      allow update: if request.auth != null
                    && request.resource.data.keys().hasOnly(['users'])
                    && request.resource.data.users.diff(resource.data.users)
                         .affectedKeys().hasOnly([request.auth.uid]);
      allow delete: if false;
    }

    // ── App config (home slider etc.) ────────────────────────
    // Read-only content; edited via console/Admin SDK only.
    match /config/{docId} {
      allow read:  if true;
      allow write: if false;
    }

    // ── Reports (moderation inbox) ───────────────────────────
    // Write-only drop box: users file reports, nobody reads them
    // from the client (review happens in the console/Admin SDK).
    match /reports/{id} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }
  }
}
