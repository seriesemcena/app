/*
  Cache-Control: no-store, max-age=0
  Content-Security-Policy: default-src 'self'; script-src 'self' https://www.recaptcha.net https://www.gstatic.com; style-src 'self'; img-src 'self' data: https:; connect-src 'self' https://api.maratonou.com https://*.googleapis.com https://*.firebaseio.com https://www.google.com wss://*.firebaseio.com; frame-src https://accounts.google.com https://*.firebaseapp.com https://www.recaptcha.net; object-src 'none'; base-uri 'none'; form-action 'self'; frame-ancestors 'none'; upgrade-insecure-requests
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  Cross-Origin-Resource-Policy: same-site
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=()
  Referrer-Policy: no-referrer
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY

/assets/*
  Cache-Control: public, max-age=31536000, immutable
