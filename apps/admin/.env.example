# Somente configurações públicas do Firebase Client SDK.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_APPCHECK_SITE_KEY=
VITE_APPCHECK_ENABLED=false
# Use a URL exata exibida pelo Firebase CLI depois do deploy da centralApi.
VITE_ADMIN_API_URL=https://us-central1-SEU_PROJECT_ID.cloudfunctions.net/centralApi

# Apenas no emulador local. Nunca definir em preview/produção.
VITE_FIREBASE_AUTH_EMULATOR_URL=
VITE_APPCHECK_DEBUG_TOKEN=
