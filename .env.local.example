# ─── TMDB ────────────────────────────────────────────────────────
# https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# ─── Giphy ───────────────────────────────────────────────────────
# https://developers.giphy.com
GIPHY_API_KEY=

# ─── Gemini (AI Curadoria) ────────────────────────────────────────
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ─── Firebase ─────────────────────────────────────────────────────
# Firebase Console → Project Settings → Your apps → Web app → Config
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# Deixe false no plano Spark. Ative somente após criar o bucket no Blaze e
# publicar storage.rules.
NEXT_PUBLIC_FIREBASE_STORAGE_ENABLED=false
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Console → Project Settings → Cloud Messaging → Web Push certificates → Key pair
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# ─── Firebase Admin (somente servidor) ───────────────────────────
# Opção A: JSON completo da conta de serviço em uma única linha.
FIREBASE_SERVICE_ACCOUNT_JSON=
# Opção B: os três campos abaixo. Nunca use NEXT_PUBLIC_ nestas chaves.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# A rota antiga /admin redireciona para a aplicação administrativa separada.
ADMIN_APP_URL=https://admin.maratonou.com

# Firebase App Check (modo monitor primeiro; veja docs/firebase-app-check.md)
NEXT_PUBLIC_FIREBASE_APPCHECK_SITE_KEY=
NEXT_PUBLIC_APPCHECK_ENABLED=false
NEXT_PUBLIC_APPCHECK_DEBUG_TOKEN=

# ─── Capacitor / Mobile ──────────────────────────────────────────
# URL of the deployed Next.js backend (Vercel) — used by the mobile app
# to call API routes (/api/tmdb, /api/ai-curation, etc.)
NEXT_PUBLIC_API_URL=https://your-app.vercel.app
